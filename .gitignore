# IntelliProfile .gitignore

# Personal portfolio page (not project-related)
portfolio.html

# Design/prompt doc (not source code)
Intellix_Production_Implementation_Prompt.md

# Generated profile results
profile_results.json

# PDFs (generated/static assets not under version control)
*.pdf

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Stale legacy files (pre-existing, unrelated to current project)
app.js
index.html
styles.css

# Trained ML models (regenerated on each run)
models/
*.joblib

# Virtual environment
venv/
.env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
